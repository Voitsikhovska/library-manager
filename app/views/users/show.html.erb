<div class="container mx-auto px-4 py-8 max-w-md">
  <h1 class="text-3xl font-bold mb-6">User Profile</h1>

  <div class="bg-white border border-gray-200 rounded-lg p-6 space-y-4">
    <div>
      <h2 class="text-gray-600 font-semibold">Name</h2>
      <p class="text-lg"><%= @user.name %></p>
    </div>

    <div>
      <h2 class="text-gray-600 font-semibold">Email</h2>
      <p class="text-lg"><%= @user.email %></p>
    </div>

    <div>
      <h2 class="text-gray-600 font-semibold">Books in Library</h2>
      <p class="text-lg"><%= @user.books.count %></p>
    </div>
  </div>

  <div class="mt-6 flex gap-2">
    <% if current_user == @user %>
      <%= link_to "View My Books", books_path, class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
      <%= link_to "Log Out", logout_path, method: :delete, class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700" %>
    <% end %>
  </div>
</div>
