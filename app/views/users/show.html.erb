<div class="container mx-auto px-4 py-8 max-w-6xl">
  <!-- Profile Header -->
  <div class="bg-gradient-to-r from-blue-500 to-blue-700 text-white rounded-lg shadow-xl p-8 mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-4xl font-bold mb-2"><%= @user.name %></h1>
        <p class="text-blue-100 text-lg"><%= @user.email %></p>
        <p class="text-blue-200 text-sm mt-2">Member since <%= @user.created_at.strftime("%B %Y") %></p>
      </div>
      <div class="text-right">
        <svg class="w-24 h-24 text-blue-300" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Statistics Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-blue-500">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-600 font-semibold">Books Added</p>
          <p class="text-3xl font-bold text-gray-800"><%= @user.books.count %></p>
        </div>
        <svg class="w-12 h-12 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
        </svg>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-green-500">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-600 font-semibold">Authors Created</p>
          <p class="text-3xl font-bold text-gray-800"><%= @user.authors.count %></p>
        </div>
        <svg class="w-12 h-12 text-green-500" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
        </svg>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-purple-500">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-600 font-semibold">Total Library Books</p>
          <p class="text-3xl font-bold text-gray-800"><%= Book.count %></p>
        </div>
        <svg class="w-12 h-12 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm5 6a1 1 0 10-2 0v3.586l-1.293-1.293a1 1 0 10-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 11.586V8z" clip-rule="evenodd"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Recent Books -->
  <% if @user.books.any? %>
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4 text-gray-800">📚 My Recent Books</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @user.books.order(created_at: :desc).limit(6).each do |book| %>
          <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition">
            <h3 class="font-bold text-lg mb-1">
              <%= link_to book.title, book_path(book), class: "text-blue-600 hover:underline" %>
            </h3>
            <p class="text-gray-600 text-sm mb-1">
              by <%= link_to book.author.name, author_path(book.author), class: "text-blue-600 hover:underline" %>
            </p>
            <p class="text-gray-500 text-xs">
              Added <%= time_ago_in_words(book.created_at) %> ago
            </p>
          </div>
        <% end %>
      </div>
      <% if @user.books.count > 6 %>
        <div class="mt-4 text-center">
          <%= link_to "View All My Books →", books_path(user_id: @user.id), class: "text-blue-600 hover:underline font-semibold" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Recent Authors -->
  <% if @user.authors.any? %>
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4 text-gray-800">✍️ Authors I Created</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @user.authors.order(created_at: :desc).limit(6).each do |author| %>
          <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition">
            <h3 class="font-bold text-lg mb-1">
              <%= link_to author.name, author_path(author), class: "text-blue-600 hover:underline" %>
            </h3>
            <p class="text-gray-600 text-sm mb-1">
              <%= pluralize(author.books.count, 'book') %>
            </p>
            <p class="text-gray-500 text-xs">
              Created <%= time_ago_in_words(author.created_at) %> ago
            </p>
          </div>
        <% end %>
      </div>
      <% if @user.authors.count > 6 %>
        <div class="mt-4 text-center">
          <%= link_to "View All Authors →", authors_path, class: "text-blue-600 hover:underline font-semibold" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Quick Actions -->
  <div class="bg-white rounded-lg shadow-md p-6">
    <h2 class="text-2xl font-bold mb-6 text-gray-800">Quick Actions</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <a href="<%= books_path %>" class="flex flex-col items-center p-6 bg-blue-50 border-2 border-blue-200 rounded-xl hover:bg-blue-100 hover:border-blue-400 hover:shadow-md transition-all text-center no-underline">
        <svg class="w-10 h-10 mb-3 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/>
        </svg>
        <span class="font-semibold text-blue-800">Browse Books</span>
        <span class="text-xs text-blue-600 mt-1">View all books</span>
      </a>

      <a href="<%= new_book_path %>" class="flex flex-col items-center p-6 bg-green-50 border-2 border-green-200 rounded-xl hover:bg-green-100 hover:border-green-400 hover:shadow-md transition-all text-center no-underline">
        <svg class="w-10 h-10 mb-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd"/>
        </svg>
        <span class="font-semibold text-green-800">Add Book</span>
        <span class="text-xs text-green-600 mt-1">Create new book</span>
      </a>

      <a href="<%= authors_path %>" class="flex flex-col items-center p-6 bg-purple-50 border-2 border-purple-200 rounded-xl hover:bg-purple-100 hover:border-purple-400 hover:shadow-md transition-all text-center no-underline">
        <svg class="w-10 h-10 mb-3 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
          <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
        </svg>
        <span class="font-semibold text-purple-800">Browse Authors</span>
        <span class="text-xs text-purple-600 mt-1">View all authors</span>
      </a>

      <% if current_user == @user %>
        <%= form_with(url: logout_path, method: :delete, data: { turbo: false }) do |f| %>
          <button type="submit" class="w-full flex flex-col items-center p-6 bg-red-50 border-2 border-red-200 rounded-xl hover:bg-red-100 hover:border-red-400 hover:shadow-md transition-all text-center cursor-pointer">
            <svg class="w-10 h-10 mb-3 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/>
            </svg>
            <span class="font-semibold text-red-800">Log Out</span>
            <span class="text-xs text-red-600 mt-1">Sign out</span>
          </button>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
