<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-500 to-purple-600 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full bg-white rounded-lg shadow-2xl p-8">
    <div class="text-center mb-8">
      <svg class="mx-auto h-16 w-16 text-blue-600 mb-4" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
      </svg>
      <h1 class="text-3xl font-bold text-gray-800">Welcome Back!</h1>
      <p class="text-gray-600 mt-2">Log in to your library account</p>
    </div>

    <%= form_with(url: login_path, local: true) do |form| %>
      <div class="mb-5">
        <%= form.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
            </svg>
          </div>
          <%= form.email_field :email, name: "session[email]", class: "pl-10 w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition", placeholder: "you@example.com" %>
        </div>
      </div>

      <div class="mb-6">
        <%= form.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
            </svg>
          </div>
          <%= form.password_field :password, name: "session[password]", class: "pl-10 w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition", placeholder: "Enter your password" %>
        </div>
      </div>

      <div class="mb-6">
        <%= form.submit "Log In", class: "w-full px-4 py-3 bg-gradient-to-r from-blue-600 to-blue-700 text-white font-semibold rounded-lg hover:from-blue-700 hover:to-blue-800 transition shadow-md hover:shadow-lg transform hover:-translate-y-0.5" %>
      </div>
    <% end %>

    <div class="text-center">
      <p class="text-gray-600">
        Don't have an account?
        <%= link_to "Sign Up", signup_path, class: "text-blue-600 font-semibold hover:text-blue-700 transition" %>
      </p>
      <p class="mt-4">
        <%= link_to "← Back to Home", root_path, class: "text-gray-600 hover:text-gray-800 transition" %>
      </p>
    </div>
  </div>
</div>
