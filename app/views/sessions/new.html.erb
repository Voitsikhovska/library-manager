<div class="container mx-auto px-4 py-8 max-w-md">
  <h1 class="text-3xl font-bold mb-6">Log In</h1>

  <%= form_with(url: login_path, local: true) do |form| %>
    <div class="mb-4">
      <%= form.label :email, "Email" %>
      <%= form.email_field :email, name: "session[email]", class: "w-full px-3 py-2 border border-gray-300 rounded" %>
    </div>

    <div class="mb-6">
      <%= form.label :password %>
      <%= form.password_field :password, name: "session[password]", class: "w-full px-3 py-2 border border-gray-300 rounded" %>
    </div>

    <div class="mb-4">
      <%= form.submit "Log In", class: "w-full px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700" %>
    </div>
  <% end %>

  <p class="text-center mt-4">
    Don't have an account? <%= link_to "Sign Up", signup_path, class: "text-blue-600 hover:underline" %>
  </p>
</div>
