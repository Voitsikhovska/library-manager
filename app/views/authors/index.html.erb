<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-4xl font-bold">Authors</h1>
    <% if logged_in? %>
      <%= link_to "Add New Author", new_author_path, class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
    <% end %>
  </div>

  <div class="mb-6">
    <%= form_with(url: authors_path, method: :get, local: true) do |form| %>
      <div class="flex gap-2">
        <%= form.text_field :search, placeholder: "Search by name or bio...", class: "flex-1 px-3 py-2 border border-gray-300 rounded" %>
        <%= form.submit "Search", class: "px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700" %>
        <% if params[:search].present? %>
          <%= link_to "Clear", authors_path, class: "px-4 py-2 bg-gray-400 text-white rounded hover:bg-gray-500" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @authors.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @authors.each do |author| %>
        <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg">
          <h2 class="text-xl font-bold mb-2"><%= link_to author.name, author, class: "text-blue-600 hover:underline" %></h2>
          
          <div class="text-gray-600 mb-2">
            <% if author.birth_year %>
              <p><strong>Born:</strong> <%= author.birth_year %></p>
            <% end %>
            <p><strong>Books:</strong> <%= author.books.count %></p>
          </div>

          <p class="text-gray-700 mb-4"><%= truncate(author.bio, length: 100) %></p>

          <div class="flex gap-2">
            <%= link_to "View", author, class: "px-3 py-1 bg-blue-600 text-white rounded text-sm hover:bg-blue-700" %>
            <% if logged_in? %>
              <%= link_to "Edit", edit_author_path(author), class: "px-3 py-1 bg-yellow-600 text-white rounded text-sm hover:bg-yellow-700" %>
              <%= link_to "Delete", author, method: :delete, data: { confirm: "This will delete the author and all their books. Are you sure?" }, class: "px-3 py-1 bg-red-600 text-white rounded text-sm hover:bg-red-700" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-100 border border-gray-300 rounded-lg p-6 text-center">
      <p class="text-gray-600 text-lg">No authors found.</p>
      <% if logged_in? %>
        <p class="mt-2"><%= link_to "Add the first author", new_author_path, class: "text-blue-600 hover:underline" %></p>
      <% end %>
    </div>
  <% end %>
</div>
