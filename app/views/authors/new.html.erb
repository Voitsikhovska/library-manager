<div class="container mx-auto px-4 py-8 max-w-2xl">
  <h1 class="text-3xl font-bold mb-6">Add New Author</h1>

  <% if @author.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <h2 class="font-bold"><%= pluralize(@author.errors.count, "error") %> prohibited this author from being saved:</h2>
      <ul class="list-disc list-inside">
        <% @author.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <%= form_with(model: @author, local: true) do |form| %>
      <div class="mb-4">
        <%= form.label :name %>
        <%= form.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div class="mb-4">
        <%= form.label :birth_year, "Birth Year" %>
        <%= form.number_field :birth_year, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div class="mb-6">
        <%= form.label :bio %>
        <%= form.text_area :bio, rows: 6, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div class="flex gap-2">
        <%= form.submit "Create Author", class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
        <%= link_to "Cancel", authors_path, class: "px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700" %>
      </div>
    <% end %>
  </div>
</div>
