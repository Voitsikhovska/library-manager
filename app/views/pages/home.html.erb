<div class="container mx-auto px-4 py-8">
  <h1 class="text-4xl font-bold mb-6">Welcome to Library Manager</h1>
  
  <% if logged_in? %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
      <p>Welcome back, <strong><%= current_user.name %></strong>!</p>
    </div>
    
    <div class="space-y-4">
      <p class="text-lg">Manage your library:</p>
      <ul class="list-disc list-inside space-y-2">
        <li><%= link_to "View all books", books_path, class: "text-blue-600 hover:underline" %></li>
        <li><%= link_to "Add a new book", new_book_path, class: "text-blue-600 hover:underline" %></li>
        <li><%= link_to "View authors", authors_path, class: "text-blue-600 hover:underline" %></li>
      </ul>
    </div>
  <% else %>
    <div class="space-y-4">
      <p class="text-xl mb-6">Please log in or sign up to get started.</p>
      <div class="flex gap-4">
        <%= link_to "Sign Up", signup_path, class: "px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
        <%= link_to "Log In", login_path, class: "px-6 py-2 bg-green-600 text-white rounded hover:bg-green-700" %>
      </div>
    </div>
  <% end %>
</div>
