<div class="container mx-auto px-4 py-12">
  <% if logged_in? %>
    <!-- Welcome Section -->
    <div class="bg-gradient-to-r from-blue-500 to-blue-700 text-white rounded-lg shadow-xl p-8 mb-8">
      <h1 class="text-4xl font-bold mb-4">Welcome back, <%= current_user.name %>! 👋</h1>
      <p class="text-xl text-blue-100">Manage your library collection with ease</p>
    </div>
    
    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-blue-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 font-semibold">Your Books</p>
            <p class="text-3xl font-bold text-gray-800"><%= current_user.books.count %></p>
          </div>
          <svg class="w-12 h-12 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
          </svg>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-green-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 font-semibold">Total Books</p>
            <p class="text-3xl font-bold text-gray-800"><%= Book.count %></p>
          </div>
          <svg class="w-12 h-12 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm5 6a1 1 0 10-2 0v3.586l-1.293-1.293a1 1 0 10-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 11.586V8z" clip-rule="evenodd"/>
          </svg>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-purple-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 font-semibold">Total Authors</p>
            <p class="text-3xl font-bold text-gray-800"><%= Author.count %></p>
          </div>
          <svg class="w-12 h-12 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="bg-white rounded-lg shadow-md p-8">
      <h2 class="text-2xl font-bold mb-6 text-gray-800">Quick Actions</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <%= link_to books_path, class: "flex items-center gap-3 p-4 border-2 border-gray-200 rounded-lg hover:border-blue-500 hover:shadow-md transition-all" do %>
          <svg class="w-8 h-8 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/>
          </svg>
          <div>
            <p class="font-semibold text-gray-800">Browse Books</p>
            <p class="text-sm text-gray-600">View all books</p>
          </div>
        <% end %>

        <%= link_to new_book_path, class: "flex items-center gap-3 p-4 border-2 border-gray-200 rounded-lg hover:border-green-500 hover:shadow-md transition-all" do %>
          <svg class="w-8 h-8 text-green-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd"/>
          </svg>
          <div>
            <p class="font-semibold text-gray-800">Add Book</p>
            <p class="text-sm text-gray-600">Add new book</p>
          </div>
        <% end %>

        <%= link_to authors_path, class: "flex items-center gap-3 p-4 border-2 border-gray-200 rounded-lg hover:border-purple-500 hover:shadow-md transition-all" do %>
          <svg class="w-8 h-8 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
            <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
          </svg>
          <div>
            <p class="font-semibold text-gray-800">Browse Authors</p>
            <p class="text-sm text-gray-600">View all authors</p>
          </div>
        <% end %>

        <%= link_to new_author_path, class: "flex items-center gap-3 p-4 border-2 border-gray-200 rounded-lg hover:border-yellow-500 hover:shadow-md transition-all" do %>
          <svg class="w-8 h-8 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
            <path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h-1V7z"/>
          </svg>
          <div>
            <p class="font-semibold text-gray-800">Add Author</p>
            <p class="text-sm text-gray-600">Create new author</p>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <!-- Hero Section for Non-logged in Users -->
    <div class="text-center py-20">
      <div class="mb-8">
        <svg class="w-24 h-24 mx-auto text-blue-600 mb-6" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
        </svg>
        <h1 class="text-5xl font-bold mb-4 text-gray-800">Welcome to Library Manager</h1>
        <p class="text-xl text-gray-600 mb-8">Your personal digital library at your fingertips</p>
      </div>

      <div class="flex gap-4 justify-center mb-12">
        <%= link_to "Get Started - Sign Up", signup_path, class: "px-8 py-4 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-lg font-semibold shadow-lg hover:shadow-xl" %>
        <%= link_to "Log In", login_path, class: "px-8 py-4 bg-green-600 text-white rounded-lg hover:bg-green-700 transition text-lg font-semibold shadow-lg hover:shadow-xl" %>
      </div>

      <!-- Features Section -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16 max-w-5xl mx-auto">
        <div class="bg-white p-6 rounded-lg shadow-md">
          <svg class="w-12 h-12 text-blue-600 mx-auto mb-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
          </svg>
          <h3 class="font-bold text-lg mb-2">Manage Books</h3>
          <p class="text-gray-600">Add, edit, and organize your book collection with ease</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md">
          <svg class="w-12 h-12 text-green-600 mx-auto mb-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"/>
            <path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd"/>
          </svg>
          <h3 class="font-bold text-lg mb-2">Track Authors</h3>
          <p class="text-gray-600">Organize books by authors and manage their information</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md">
          <svg class="w-12 h-12 text-purple-600 mx-auto mb-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M3 3a1 1 0 000 2v8a2 2 0 002 2h2.586l-1.293 1.293a1 1 0 101.414 1.414L10 15.414l2.293 2.293a1 1 0 001.414-1.414L12.414 15H15a2 2 0 002-2V5a1 1 0 100-2H3zm11.707 4.707a1 1 0 00-1.414-1.414L10 9.586 8.707 8.293a1 1 0 00-1.414 0l-2 2a1 1 0 101.414 1.414L8 10.414l1.293 1.293a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <h3 class="font-bold text-lg mb-2">Export Data</h3>
          <p class="text-gray-600">Export your library to CSV or JSON formats</p>
        </div>
      </div>
    </div>
  <% end %>
</div>
