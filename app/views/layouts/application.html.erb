<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Library Manager" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen flex flex-col bg-gray-50">
    <nav class="bg-gradient-to-r from-blue-600 to-blue-800 text-white px-4 py-4 shadow-lg">
      <div class="container mx-auto flex justify-between items-center">
        <div class="flex items-center gap-4">
          <%= link_to root_path, class: "text-2xl font-bold hover:text-blue-200 transition flex items-center gap-2" do %>
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
            </svg>
            <span>Library Manager</span>
          <% end %>
        </div>
        <div class="flex gap-6 items-center">
          <%= link_to "Books", books_path, class: "hover:text-blue-200 transition font-medium" %>
          <%= link_to "Authors", authors_path, class: "hover:text-blue-200 transition font-medium" %>
          <% if logged_in? %>
            <div class="flex items-center gap-4">
              <span class="text-sm bg-blue-700 px-3 py-1 rounded-full">👤 <%= current_user.name %></span>
              <%= link_to "My Profile", current_user, class: "hover:text-blue-200 transition" %>
              <%= button_to "Log Out", logout_path, method: :delete, class: "bg-red-600 px-4 py-2 rounded hover:bg-red-700 transition", form: { style: "display: inline-block;" } %>
            </div>
          <% else %>
            <%= link_to "Sign Up", signup_path, class: "hover:text-blue-200 transition" %>
            <%= link_to "Log In", login_path, class: "bg-green-600 px-4 py-2 rounded hover:bg-green-700 transition font-medium" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="bg-green-100 border-l-4 border-green-500 text-green-700 px-4 py-3 m-4 rounded shadow-md animate-fade-in">
        <div class="flex items-center">
          <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="bg-red-100 border-l-4 border-red-500 text-red-700 px-4 py-3 m-4 rounded shadow-md animate-fade-in">
        <div class="flex items-center">
          <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main class="flex-grow">
      <%= yield %>
    </main>

    <footer class="bg-gray-800 text-white mt-12 py-8">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-lg font-bold mb-4">Library Manager</h3>
            <p class="text-gray-400">A comprehensive solution for managing your book collection and authors.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-4">Quick Links</h3>
            <ul class="space-y-2 text-gray-400">
              <li><%= link_to "Browse Books", books_path, class: "hover:text-white transition" %></li>
              <li><%= link_to "Browse Authors", authors_path, class: "hover:text-white transition" %></li>
              <% if logged_in? %>
                <li><%= link_to "Add Book", new_book_path, class: "hover:text-white transition" %></li>
                <li><%= link_to "Add Author", new_author_path, class: "hover:text-white transition" %></li>
              <% end %>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-4">Features</h3>
            <ul class="space-y-2 text-gray-400">
              <li>✓ Search & Filter</li>
              <li>✓ Export to CSV/JSON</li>
              <li>✓ User Management</li>
              <li>✓ Author Tracking</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-6 text-center text-gray-400">
          <p>&copy; <%= Date.current.year %> Library Manager. Built with Ruby on Rails.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
