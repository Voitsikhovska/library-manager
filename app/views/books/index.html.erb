<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-4xl font-bold">Books Library</h1>
    <% if logged_in? %>
      <%= link_to "Add New Book", new_book_path, class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
    <% end %>
  </div>

  <div class="mb-6 bg-white border border-gray-200 rounded-lg p-6">
    <h2 class="text-xl font-bold mb-4">Filter Books</h2>
    <%= form_with(url: books_path, method: :get, local: true) do |form| %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div>
          <%= form.text_field :search, placeholder: "Search title, description, ISBN...", value: params[:search], class: "w-full px-3 py-2 border border-gray-300 rounded" %>
        </div>

        <div>
          <%= form.collection_select :author_id, @authors, :id, :name, { prompt: "All Authors", selected: params[:author_id] }, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
        </div>

        <div>
          <%= form.number_field :year_from, placeholder: "From Year", value: params[:year_from], class: "w-full px-3 py-2 border border-gray-300 rounded" %>
        </div>

        <div>
          <%= form.number_field :year_to, placeholder: "To Year", value: params[:year_to], class: "w-full px-3 py-2 border border-gray-300 rounded" %>
        </div>
      </div>

      <div class="mt-4 flex gap-2">
        <%= form.submit "Filter", class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
        <% if params[:search].present? || params[:author_id].present? || params[:year_from].present? || params[:year_to].present? %>
          <%= link_to "Clear Filters", books_path, class: "px-4 py-2 bg-gray-400 text-white rounded hover:bg-gray-500" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="mb-4 flex justify-between items-center">
    <p class="text-gray-600"><%= pluralize(@books.count, "book") %> found</p>
    <div class="flex gap-4 items-center">
      <div>
        <%= form_with(url: books_path, method: :get, local: true, style: "display: inline-block;") do |form| %>
          <%= form.hidden_field :search, value: params[:search] %>
          <%= form.hidden_field :author_id, value: params[:author_id] %>
          <%= form.hidden_field :year_from, value: params[:year_from] %>
          <%= form.hidden_field :year_to, value: params[:year_to] %>
          Sort by:
          <%= form.select :sort, [["Most Recent", "recent"], ["Title A-Z", "title_asc"]], { selected: params[:sort] || "recent" }, class: "py-1 border border-gray-300 rounded" %>
          <%= form.submit "Sort", class: "px-2 py-1 bg-gray-600 text-white rounded text-sm hover:bg-gray-700" %>
        <% end %>
      </div>
      
      <div class="flex gap-2">
        <span class="text-gray-600 text-sm">Export:</span>
        <%= form_with(url: export_books_path, method: :post, data: { turbo: false }, style: "display: inline-block;") do |form| %>
          <%= form.hidden_field :search, value: params[:search] %>
          <%= form.hidden_field :author_id, value: params[:author_id] %>
          <%= form.hidden_field :year_from, value: params[:year_from] %>
          <%= form.hidden_field :year_to, value: params[:year_to] %>
          <%= form.hidden_field :export_format, value: 'csv' %>
          <%= form.submit "CSV", class: "px-2 py-1 bg-green-600 text-white rounded text-sm hover:bg-green-700" %>
        <% end %>
        <%= form_with(url: export_books_path, method: :post, data: { turbo: false }, style: "display: inline-block;") do |form| %>
          <%= form.hidden_field :search, value: params[:search] %>
          <%= form.hidden_field :author_id, value: params[:author_id] %>
          <%= form.hidden_field :year_from, value: params[:year_from] %>
          <%= form.hidden_field :year_to, value: params[:year_to] %>
          <%= form.hidden_field :export_format, value: 'json' %>
          <%= form.submit "JSON", class: "px-2 py-1 bg-purple-600 text-white rounded text-sm hover:bg-purple-700" %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @books.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @books.each do |book| %>
        <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow duration-200">
          <h2 class="text-xl font-bold mb-2"><%= link_to book.title, book, class: "text-blue-600 hover:underline" %></h2>
          
          <div class="text-gray-600 mb-2">
            <p><strong>Author:</strong> <%= link_to book.author.name, author_path(book.author), class: "text-blue-600 hover:underline" %></p>
            <p><strong>ISBN:</strong> <%= book.isbn %></p>
            <% if book.published_year %>
              <p><strong>Published:</strong> <%= book.published_year %></p>
            <% end %>
          </div>

          <p class="text-gray-700 mb-4"><%= truncate(book.description, length: 100) %></p>

          <div class="text-gray-500 text-sm mb-4">
            <p><strong>Added by:</strong> <%= book.user.name %></p>
          </div>

          <div class="flex gap-2">
            <%= link_to "View", book, class: "px-3 py-1 bg-blue-600 text-white rounded text-sm hover:bg-blue-700 transition" %>
            <% if logged_in? && book.user == current_user %>
              <%= link_to "Edit", edit_book_path(book), class: "px-3 py-1 bg-yellow-600 text-white rounded text-sm hover:bg-yellow-700 transition" %>
              <%= button_to "Delete", book, method: :delete, data: { confirm: "Are you sure?" }, class: "px-3 py-1 bg-red-600 text-white rounded text-sm hover:bg-red-700 transition", form: { style: "display: inline-block;" } %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-100 border border-gray-300 rounded-lg p-6 text-center">
      <p class="text-gray-600 text-lg">No books found.</p>
      <% if logged_in? %>
        <p class="mt-2"><%= link_to "Add the first book", new_book_path, class: "text-blue-600 hover:underline" %></p>
      <% end %>
    </div>
  <% end %>
</div>
