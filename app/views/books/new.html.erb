<div class="container mx-auto px-4 py-8 max-w-2xl">
  <h1 class="text-3xl font-bold mb-6">Add New Book</h1>

  <% if @book.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <h2 class="font-bold"><%= pluralize(@book.errors.count, "error") %> prohibited this book from being saved:</h2>
      <ul class="list-disc list-inside">
        <% @book.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <%= form_with(model: @book, local: true) do |form| %>
      <div class="mb-4">
        <%= form.label :title %>
        <%= form.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div class="mb-4">
        <%= form.label :author_id %>
        <%= form.collection_select :author_id, Author.all, :id, :name, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div class="mb-4">
        <%= form.label :isbn %>
        <%= form.text_field :isbn, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div class="mb-4">
        <%= form.label :published_year %>
        <%= form.number_field :published_year, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div class="mb-6">
        <%= form.label :description %>
        <%= form.text_area :description, rows: 6, class: "w-full px-3 py-2 border border-gray-300 rounded" %>
      </div>

      <div class="flex gap-2">
        <%= form.submit "Create Book", class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
        <%= link_to "Cancel", books_path, class: "px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700" %>
      </div>
    <% end %>
  </div>
</div>
