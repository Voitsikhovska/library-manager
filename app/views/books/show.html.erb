<div class="container mx-auto px-4 py-8 max-w-2xl">
  <div class="bg-white border border-gray-200 rounded-lg p-8">
    <h1 class="text-4xl font-bold mb-4"><%= @book.title %></h1>
    
    <div class="grid grid-cols-2 gap-4 mb-6">
      <div>
        <h2 class="text-gray-600 font-semibold">Author</h2>
        <p class="text-lg"><%= link_to @book.author.name, author_path(@book.author), class: "text-blue-600 hover:underline" %></p>
      </div>
      
      <div>
        <h2 class="text-gray-600 font-semibold">ISBN</h2>
        <p class="text-lg"><%= @book.isbn %></p>
      </div>
      
      <% if @book.published_year %>
        <div>
          <h2 class="text-gray-600 font-semibold">Published Year</h2>
          <p class="text-lg"><%= @book.published_year %></p>
        </div>
      <% end %>
      
      <div>
        <h2 class="text-gray-600 font-semibold">Added by</h2>
        <p class="text-lg"><%= link_to @book.user.name, user_path(@book.user), class: "text-blue-600 hover:underline" %></p>
      </div>
    </div>
    
    <div class="mb-6">
      <h2 class="text-gray-600 font-semibold mb-2">Description</h2>
      <p class="text-gray-700 leading-relaxed"><%= simple_format(@book.description) %></p>
    </div>
    
    <div class="flex gap-2">
      <%= link_to "Back to Books", books_path, class: "px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700" %>
      <% if logged_in? && @book.user == current_user %>
        <%= link_to "Edit", edit_book_path(@book), class: "px-4 py-2 bg-yellow-600 text-white rounded hover:bg-yellow-700" %>
        <%= button_to "Delete", @book, method: :delete, data: { confirm: "Are you sure?" }, class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700", form: { style: "display: inline-block;" } %>
      <% end %>
    </div>
  </div>
</div>
